# 宝塔 / Linux 部署环境变量示例
# 复制为 /www/wwwroot/poster/.env 或在 systemd 中配置

# 监听地址（仅本机反代时保持 127.0.0.1）
HOST=127.0.0.1
PORT=8010

# HTTPS 站点可留空，将自动根据 X-Forwarded-Proto 设置 Secure Cookie
# 纯 HTTP 测试时设为 0
POSTER_SECURE_COOKIE=

# 管理员账号（首次启动无管理员时自动创建）
ADMIN_PHONE=13800000000
ADMIN_PASSWORD=请改为强密码

# 首次部署或密码无法登录时设为 1，重启后按上面密码重置管理员，成功后改回 0
ADMIN_SYNC_PASSWORD=0

# 支付截图：1=上传后自动开通额度；0=待管理员审核。后台可对异常记录紧急叫停。
PAYMENT_AUTO_APPROVE=1

# 参考图上传安全上限。默认 30，已取消原 3 张限制。
MAX_REFERENCE_IMAGES=30

# 可选：注册/支付事件 webhook
# ADMIN_NOTIFY_URL=https://your-domain.com/hook

# 统一认证（本地 / 云端）
# AUTH_BASE_URL=https://ai.ms1001.com

# Minimax 批量规划（本地可自动读取 ../Gaokao/.env；云端请在此配置）
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-M3
