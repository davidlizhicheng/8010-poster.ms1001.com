# Copy to .env (gitignored) or rely on ../Gaokao/.env auto-load at startup.

AUTH_BASE_URL=http://127.0.0.1:9080
AUTH_PORT=9080
PORT=8010

# Minimax — AI 规划清单 / 批量提示词（云端在宝塔/systemd 配置同名变量）
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M3

# Fenno 图片生成（也可写在 data/config.json）
# OPENAI_API_KEY=
